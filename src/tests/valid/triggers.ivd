spec bleeding;

.base
{
    trigger: eff;
    trigger: this.blep;
    trigger: model.notnow , model.effie;
}

#lordy -> oof: base
{
    trigger: model.doitnow;
}

//These were originally intended to merge within the same element...
// but the local overwriting seems more idiomatic.

.rebase
{
    trigger: model.elm;

state this.what:
    trigger: model.bitch;
}

# -> mod : rebase
{
    trigger: model.corn;
state this.what:
    trigger: model.witch;

state wwww:
    trigger: f;
}

//I should really think about this...
