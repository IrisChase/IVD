spec bleeding;

//This file is meant to be used as a template for writing a certain
// kind of test.

#window
{
	position-within: Environment;
	window-size-strategy: bottom-up;

    layout: vbox;

state IVD-Window-Close:
	trigger: IVD-Core-Quit;
}

.square
{
    width: 40;
    height: 40;
    margin: 5;
    color: blue;

state this.IVD-Item-Hover:
    color: green;
}

#row1
{
    layout: hbox;
    position-within: window;
}

# : square
{ position-within: row1; }
# : square
{ position-within: row1; }
# : square
{ position-within: row1; }
# : square
{ position-within: row1; }
# : square
{ position-within: row1; }

#row2
{
    layout: hbox;
    position-within: window;
}

# : square
{ position-within: row2; }
# : square
{ position-within: row2; }
# : square
{ position-within: row2; }
# : square
{ position-within: row2; }
# : square
{ position-within: row2; }
