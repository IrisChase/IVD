spec bleeding;


#window
{
	position-within: Environment;
	window-size-strategy: bottom-up;

	height: 400;
	width: 400;

	layout: vbox;

state IVD-Window-Close:
	trigger: IVD-Core-Quit;
}

.meep
{
	position-within: window;
	height: 30;
}

.cell-greedyer
{
	position-within: window;

	//height: min = 20;

	color: purple;

state  IVD-Item-Hover:
	color: orange;

state !greedy & IVD-Item-Hover & ::.IVD-Mouse-Left-Press:
	induce-state: greedy;

state greedy & IVD-Item-Hover & ::.IVD-Mouse-Left-Press:
	unset-state: greedy;

state greedy:
	greedy-y: enable;
	color: cyan;
}

# : cell-greedyer;

# : meep
{
	color: blue;
}

# : cell-greedyer;

# : meep
{
	color: green;
}

# : cell-greedyer;
